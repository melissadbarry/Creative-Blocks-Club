<script>
// multi: true = checkbox multi-select, false = single radio
var Qs = [

  // ── AUDIENCE CLARITY ──────────────────────────────────────────
  { sec:"Audience Clarity", multi: true,
    q:"Which of these best describes the people you want at Creative Blocks? Pick all that apply.",
    hint:"Select all that feel true.",
    opts:[
      {t:"People who work independently and miss the ambient energy of being around others", s:{a:3}},
      {t:"People who have a specific project, task, or backlog they keep putting off", s:{a:3}},
      {t:"People who want to meet others but find traditional networking performative", s:{a:2}},
      {t:"Anyone who needs a place to sit with wifi and get work done", s:{a:0}},
      {t:"Creative minds — writers, designers, engineers, builders — regardless of title", s:{a:2}},
      {t:"People in career transition who need structure and community", s:{a:1}}
    ]
  },

  { sec:"Audience Clarity", multi: false,
    q:"What is the ONE emotional state you want someone in when they decide to book a session?",
    hint:"Pick the one that resonates most.",
    opts:[
      {t:"\"I've been putting this off for weeks and I need external accountability to finally do it\"", s:{a:3}},
      {t:"\"I'm tired of working alone in silence — I miss being around people who care about their work\"", s:{a:3}},
      {t:"\"I want to meet interesting people but not in a networking context\"", s:{a:2}},
      {t:"\"I just need a change of scenery and some structure today\"", s:{a:1}}
    ]
  },

  { sec:"Audience Clarity", multi: true,
    q:"Which personality traits describe your ideal Creative Blocks attendee? Pick all that apply.",
    hint:"Beyond job title — who are they as a person?",
    opts:[
      {t:"Ambitious but prone to getting stuck in their own head", s:{a:3}},
      {t:"Introverted but craves meaningful, low-pressure social connection", s:{a:3}},
      {t:"Has side projects or creative work beyond their day job", s:{a:2}},
      {t:"Extroverted, energetic, loves meeting new people", s:{a:0}},
      {t:"Values depth over small talk — would rather bond over shared work than cocktail chat", s:{a:3}},
      {t:"Disciplined and organized — just needs the right environment", s:{a:1}}
    ]
  },

  { sec:"Audience Clarity", multi: false,
    q:"Someone comes to Creative Blocks and leaves feeling like it wasn't for them. What happened?",
    hint:"The wrong-fit scenario tells you a lot about who the right fit is.",
    opts:[
      {t:"They wanted more socializing during the work blocks, not just at the end", s:{a:3}},
      {t:"They didn't have real work to bring — they came out of curiosity", s:{a:2}},
      {t:"They found the silence uncomfortable and the structure too rigid", s:{a:3}},
