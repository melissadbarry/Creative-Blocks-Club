      {t:"Playful — light touch, doesn't take itself too seriously", s:{t:2}}
    ]
  },

  { sec:"Tone & Voice", multi: false,
    q:"What should someone feel the moment they land on the Creative Blocks Instagram or website?",
    hint:"One feeling, not a list.",
    opts:[
      {t:"\"Finally — someone made this.\"", s:{t:3}},
      {t:"\"This looks cool, I want to be part of this.\"", s:{t:2}},
      {t:"\"Oh interesting, tell me more.\"", s:{t:1}},
      {t:"\"This seems like a nice productivity event.\"", s:{t:0}}
