      {t:"The need for accountability that isn't surveillance — no tracking, no boss, just shared intention", s:{ph:3}},
      {t:"The need for organic connection — friendships that form through doing, not networking", s:{ph:3}},
      {t:"The need for ritual — a structured anchor in an otherwise unstructured work life", s:{ph:2}},
      {t:"The need to feel like your work matters — being around others who care reminds you that you care too", s:{ph:3}}
    ]
  },

