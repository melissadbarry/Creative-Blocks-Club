      {t:"Depth — real connection comes from doing things together, not talking about ourselves", s:{p:3}},
      {t:"Intentionality — every element of the session is designed, nothing is random", s:{p:2}},
      {t:"Inclusivity — everyone with real work to do belongs here", s:{p:2}},
      {t:"Growth — we're here to move things forward, not just feel good", s:{p:2}},
      {t:"Freedom — no performance, no pressure, show up as you are", s:{p:2}}
    ]
  },

  { sec:"Purpose & Values", multi: false,
    q:"In 5 years, Creative Blocks is...",
    hint:"Pick the future that excites you most.",
    opts:[
      {t:"A nonprofit with free community sessions in 10+ cities, run by trained local hosts, funded through retreats, offsites, merch and workshops", s:{p:3}},
      {t:"A profitable brand with sponsorships from aligned companies and a premium corporate offering", s:{p:2}},
      {t:"A tight, well-known Toronto community that I run personally and keep intentionally small", s:{p:1}},
      {t:"I honestly haven't committed to a vision yet", s:{p:0}}
    ]
  },

  // ── POSITIONING ───────────────────────────────────────────────
  { sec:"Positioning", multi: false,
    q:"What is the one thing Creative Blocks does that nothing else does?",
    hint:"Not features. The actual feeling or outcome.",
    opts:[
      {t:"It gives you the experience of working alongside coworkers — without the job, the politics, or the obligation", s:{pos:3}},
      {t:"It makes deep work social without making it performative", s:{pos:3}},
      {t:"It's free structured coworking in a real café", s:{pos:1}},
      {t:"It's a community for remote workers", s:{pos:0}}
    ]
  },

  { sec:"Positioning", multi: true,
    q:"Which of these brands or experiences has a similar energy to what you want Creative Blocks to feel like?",
    hint:"Vibes matter. Pick what resonates.",
    opts:[
      {t:"A well-designed independent coffee shop where regulars become friends", s:{pos:2}},
      {t:"A silent disco — structured, intentional, surprisingly social", s:{pos:3}},
      {t:"A writers' room — creative minds working in parallel toward their own goals", s:{pos:3}},
      {t:"A CrossFit gym — community formed through shared effort, not small talk", s:{pos:2}},
      {t:"A WeWork — professional, accessible, functional", s:{pos:0}},
      {t:"A university library — quiet, focused, but full of ambitious people", s:{pos:1}}
    ]
  },

  // ── TONE & VOICE ──────────────────────────────────────────────
  { sec:"Tone & Voice", multi: true,
    q:"Which words describe how you want Creative Blocks to sound? Pick all that feel right.",
    hint:"Honest > aspirational here.",
    opts:[
      {t:"Direct — short sentences, no fluff", s:{t:3}},
      {t:"Warm — people should feel welcomed, not evaluated", s:{t:2}},
      {t:"Confident — we know what this is and what it isn't", s:{t:3}},
      {t:"Inspiring — content that makes people want to create", s:{t:1}},
