  },

  { sec:"Business Model", multi: false,
    q:"If Creative Blocks expands to other cities, hosts are...",
    hint:"This shapes whether it scales as a movement, a franchise, or a brand.",
    opts:[
      {t:"Volunteers who run sessions because they believe in the mission", s:{b:1}},
