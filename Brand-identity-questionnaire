  {name:"The Wanderer", tagline:"Still finding your north star.", min:0, color:"#888",
   desc:"The concept is genuinely strong but the brand identity hasn't crystallized yet. That's the work. Start with audience — one specific person, one specific feeling — and everything else will follow."}
];

// Calculate max scores dynamically
DIMS.forEach(function(d) {
  var total = 0;
  Qs.forEach(function(q) {
    if (q.multi) {
      // max = sum of all opts with this key
      q.opts.forEach(function(o) { if (o.s[d.key]) total += o.s[d.key]; });
    } else {
      // max = highest single opt
      var m = 0;
      q.opts.forEach(function(o) { if (o.s[d.key] && o.s[d.key] > m) m = o.s[d.key]; });
      total += m;
    }
  });
  d.max = total || 1;
});

var cur = 0;
// answers[i] = array of selected option indices
var answers = {};

function startQuiz() {
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('quiz').classList.remove('hidden');
  render();
}

function render() {
  var q = Qs[cur];
  var pct = Math.round((cur / Qs.length) * 100);
  document.getElementById('pFill').style.width = pct + '%';
  document.getElementById('pLabel').textContent = 'Question ' + (cur+1) + ' of ' + Qs.length + ' · ' + q.sec;
  document.getElementById('backBtn').disabled = cur === 0;
  var sel = answers[cur] || [];
  document.getElementById('nextBtn').disabled = sel.length === 0;
  document.getElementById('nextBtn').textContent = cur === Qs.length - 1 ? 'See Results →' : 'Next →';

  var html = '<div class="section-tag">' + q.sec + '</div>';
  html += '<div class="q-text">' + q.q + '</div>';
  html += '<div class="q-hint">' + q.hint + '</div>';
  q.opts.forEach(function(o, i) {
    var isSel = sel.indexOf(i) > -1;
    var shape = q.multi
      ? '<div class="box"></div>'
      : '<div class="dot"></div>';
    html += '<div class="opt' + (isSel?' sel':'') + '" onclick="pick(' + i + ')">' + shape + o.t + '</div>';
  });
  document.getElementById('qCard').innerHTML = html;
}

function pick(i) {
  var q = Qs[cur];
  if (!answers[cur]) answers[cur] = [];
  if (q.multi) {
    var idx = answers[cur].indexOf(i);
    if (idx > -1) answers[cur].splice(idx, 1);
    else answers[cur].push(i);
  } else {
    answers[cur] = [i];
  }
  render();
}

function goNext() {
  var sel = answers[cur] || [];
  if (sel.length === 0) return;
  if (cur < Qs.length - 1) { cur++; render(); }
  else showResults();
}

function goBack() { if (cur > 0) { cur--; render(); } }

function showResults() {
  document.getElementById('quiz').classList.add('hidden');

  var totals = {a:0, p:0, pos:0, t:0, b:0};
  Object.keys(answers).forEach(function(qi) {
    var sel = answers[qi];
    sel.forEach(function(oi) {
      var sc = Qs[qi].opts[oi].s;
      Object.keys(sc).forEach(function(k) { totals[k] = (totals[k]||0) + sc[k]; });
    });
  });

  // Normalise each dimension 0–1
  var norms = {};
  DIMS.forEach(function(d) { norms[d.key] = Math.min(totals[d.key] / d.max, 1); });
  var overallNorm = Object.values(norms).reduce(function(a,b){return a+b;},0) / DIMS.length;
  var pct = Math.round(overallNorm * 100);

  var arch = ARCHETYPES.find(function(a){ return overallNorm >= a.min; });
  var lowest = DIMS.slice().sort(function(a,b){ return norms[a.key]-norms[b.key]; })[0];
  var scoreColor = pct >= 70 ? '#2d7a3a' : pct >= 45 ? '#b07d10' : '#c0392b';

  function lvl(key) {
    var r = norms[key];
    return r>=.75?3:r>=.45?2:r>=.2?1:0;
  }
  function tag(key) {
    var r = norms[key];
    if (r>=.75) return '<span class="tag tag-s">Strong</span>';
    if (r>=.45) return '<span class="tag tag-m">Developing</span>';
    return '<span class="tag tag-w">Needs work</span>';
  }
  function scoreFmt(key) {
    return Math.round(norms[key]*100) + '%';
  }

  var html = '<h1 style="color:#C65A2E;font-weight:normal;font-size:1.7rem;margin-bottom:4px">Your Results</h1>';
  html += '<p class="sub">Creative Blocks Club — Brand Clarity Report</p>';

  html += '<div class="card" style="border-left:4px solid ' + arch.color + '">';
  html += '<span class="arch-badge" style="background:' + arch.color + '">Brand Archetype</span>';
  html += '<div class="arch-name">' + arch.name + '</div>';
  html += '<div class="arch-tagline">"' + arch.tagline + '"</div>';
  html += '<div class="arch-desc">' + arch.desc + '</div></div>';

  html += '<div class="score-grid">';
  html += '<div class="score-card"><div class="score-num" style="color:' + scoreColor + '">' + pct + '%</div><div class="score-lbl">Overall Brand Clarity</div></div>';
  html += '<div class="score-card"><div class="score-num" style="color:#C65A2E">' + arch.name.split(' ')[1] + '</div><div class="score-lbl">Your Archetype</div></div>';
  html += '</div>';

  html += '<div class="section-divider">Dimension Breakdown</div>';

  DIMS.forEach(function(d) {
    html += '<div class="card">';
    html += '<div style="display:flex;align-items:center;flex-wrap:wrap;gap:4px">';
    html += '<span style="font-size:.95rem">' + d.label + '</span>' + tag(d.key);
    html += '<span class="dim-score">' + scoreFmt(d.key) + '</span></div>';
    html += '<div class="dim-tip">' + d.tips[lvl(d.key)] + '</div></div>';
  });

  html += '<div class="section-divider">What To Do First</div>';
  html += '<div class="card priority-card">';
  html += '<div class="priority-label">Your #1 Priority Right Now</div>';
  html += '<div class="priority-text">' + PRIORITY[lowest.key] + '</div></div>';

  html += '<div class="center"><button class="btn btn-restart" onclick="restart()">↺ Retake</button></div>';

  var el = document.getElementById('results');
  el.innerHTML = html;
  el.classList.remove('hidden');
  window.scrollTo(0,0);
}

function restart() {
  cur = 0; answers = {};
  document.getElementById('results').classList.add('hidden');
  document.getElementById('intro').classList.remove('hidden');
  window.scrollTo(0,0);
}
</script>

</body>
</html>
