    opts:[
      {t:"Deep focus — they protect their attention fiercely", s:{a:3}},
      {t:"Autonomy — they hate being micromanaged or tracked", s:{a:2}},
      {t:"Community — they believe work is better when shared", s:{a:3}},
      {t:"Output — they measure their day by what they shipped", s:{a:2}},
      {t:"Flexibility — they work when and how it suits them", s:{a:1}},
      {t:"Meaning — they want the work they do to matter", s:{a:2}}
    ]
  },

  // ── THE PHILOSOPHY ────────────────────────────────────────────
  { sec:"The Philosophy", multi: false,
    q:"If you had to remove one element from Creative Blocks, which would hurt the brand more?",
    hint:"There's no right answer — this reveals what you believe the product actually is.",
    opts:[
