  },

  // ── BUSINESS MODEL ────────────────────────────────────────────
  { sec:"Business Model", multi: true,
    q:"Which of these revenue streams feel aligned with the Creative Blocks brand? Pick all you'd pursue.",
    hint:"Think about what preserves the brand's integrity.",
    opts:[
      {t:"Brand sponsorships — specialty coffee, productivity tools, indie brands that share the values", s:{b:3}},
      {t:"Corporate offsites and team deep work days — paid, B2B version of the format", s:{b:3}},
      {t:"Retreats — multi-day immersive experiences (3–5 days, paid)", s:{b:3}},
      {t:"Monthly workshops or skill sessions (paid, optional add-on)", s:{b:2}},
      {t:"Merch — minimal, intentional, community-driven", s:{b:2}},
      {t:"A paid membership tier with premium perks", s:{b:1}},
      {t:"Grants and nonprofit funding", s:{b:2}}
