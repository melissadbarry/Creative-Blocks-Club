<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Brand Identity Questionnaire</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Georgia', serif; background: #f7f5f0; color: #2c2c2c; min-height: 100vh; }

.container { max-width: 720px; margin: 0 auto; padding: 40px 24px; }

h1 { font-size: 1.8rem; font-weight: normal; color: #C65A2E; margin-bottom: 6px; }
.subtitle { font-size: 0.95rem; color: #777; margin-bottom: 36px; font-family: sans-serif; }

.progress-bar { background: #e0dbd2; border-radius: 4px; height: 6px; margin-bottom: 32px; }
.progress-fill { background: #C65A2E; height: 6px; border-radius: 4px; transition: width 0.4s ease; }
.progress-label { font-family: sans-serif; font-size: 0.8rem; color: #999; margin-top: 6px; }

.section-label { font-family: sans-serif; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: #C65A2E; margin-bottom: 8px; }
.question-card { background: white; border-radius: 12px; padding: 28px; margin-bottom: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
.question-text { font-size: 1.05rem; margin-bottom: 18px; line-height: 1.5; }

.options { display: flex; flex-direction: column; gap: 10px; }
.option { display: flex; align-items: flex-start; gap: 12px; padding: 12px 16px; border: 2px solid #e8e4dc; border-radius: 8px; cursor: pointer; transition: all 0.2s; font-family: sans-serif; font-size: 0.9rem; line-height: 1.4; }
.option:hover { border-color: #C65A2E; background: #fdf8f5; }
.option.selected { border-color: #C65A2E; background: #fdf8f5; }
.option input[type=“radio”] { margin-top: 2px; accent-color: #C65A2E; flex-shrink: 0; }

.nav { display: flex; justify-content: space-between; margin-top: 32px; }
button { font-family: sans-serif; font-size: 0.9rem; padding: 12px 28px; border: none; border-radius: 8px; cursor: pointer; transition: all 0.2s; }
.btn-next { background: #C65A2E; color: white; }
.btn-next:hover { background: #a8481f; }
.btn-next:disabled { background: #ddd; cursor: not-allowed; }
.btn-back { background: transparent; color: #999; border: 2px solid #e0dbd2; }
.btn-back:hover { border-color: #999; color: #555; }

/* Results */
.results { display: none; }
.archetype-badge { background: #C65A2E; color: white; display: inline-block; padding: 6px 16px; border-radius: 20px; font-family: sans-serif; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px; }
.archetype-name { font-size: 2rem; color: #2c2c2c; margin-bottom: 8px; }
.archetype-tagline { font-size: 1rem; color: #888; font-family: sans-serif; margin-bottom: 28px; }

.score-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 28px; }
.score-card { background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.score-num { font-size: 2.2rem; font-weight: bold; }
.score-label { font-family: sans-serif; font-size: 0.8rem; color: #999; margin-top: 4px; }

.section-result { background: white; border-radius: 12px; padding: 24px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.section-result h3 { font-size: 1rem; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
.tag { font-family: sans-serif; font-size: 0.7rem; padding: 3px 10px; border-radius: 12px; font-weight: normal; }
.tag-strong { background: #e6f4ea; color: #2d7a3a; }
.tag-medium { background: #fff8e1; color: #b07d10; }
.tag-weak { background: #fdecea; color: #c0392b; }
.section-result p { font-family: sans-serif; font-size: 0.88rem; color: #555; line-height: 1.6; margin-top: 8px; }

.cta-restart { margin-top: 24px; text-align: center; }
.btn-restart { background: transparent; border: 2px solid #C65A2E; color: #C65A2E; }
.btn-restart:hover { background: #C65A2E; color: white; }

.intro { background: white; border-radius: 12px; padding: 32px; margin-bottom: 32px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
.intro h2 { font-size: 1.2rem; margin-bottom: 12px; }
.intro p { font-family: sans-serif; font-size: 0.9rem; color: #666; line-height: 1.7; }
.btn-start { background: #C65A2E; color: white; font-size: 1rem; padding: 14px 36px; border-radius: 10px; display: block; margin: 24px auto 0; }
</style>

</head>
<body>
<div class="container">
  <h1>Brand Clarity Questionnaire</h1>
  <p class="subtitle">Creative Blocks Club · ~3 min · 12 questions</p>

  <!-- Intro -->

  <div id="intro" class="intro">
    <h2>Let's figure out who this brand really is.</h2>
    <p>This questionnaire covers 5 dimensions of brand identity: <strong>audience clarity</strong>, <strong>purpose & values</strong>, <strong>positioning</strong>, <strong>tone & voice</strong>, and <strong>business model alignment</strong>.</p>
    <p style="margin-top:12px">At the end, you'll get a brand archetype, a clarity score, and specific recommendations on what to fix first.</p>
    <button class="btn-start" onclick="startQuiz()">Start →</button>
  </div>

  <!-- Quiz -->

  <div id="quiz" style="display:none">
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    <div class="progress-label" id="progressLabel"></div>
    <div id="questionWrap"></div>
    <div class="nav">
      <button class="btn-back" id="backBtn" onclick="goBack()">← Back</button>
      <button class="btn-next" id="nextBtn" onclick="goNext()" disabled>Next →</button>
    </div>
  </div>

  <!-- Results -->

  <div id="results" class="results"></div>
</div>

<script>
const questions = [
  // AUDIENCE CLARITY
  { section: "Audience Clarity", q: "Who is the primary person you picture when you plan a Creative Blocks session?", opts: [
    { text: "Remote workers who feel isolated and miss having real coworkers", score: { audience: 3 } },
    { text: "Freelancers and solopreneurs who struggle with self-discipline", score: { audience: 2 } },
    { text: "Anyone who needs to get work done — remote, hybrid, or otherwise", score: { audience: 0 } },
    { text: "Job seekers and career transitioners looking for structure", score: { audience: 1 } }
  ]},
  { section: "Audience Clarity", q: "What is the single biggest emotional pain point of your ideal attendee?", opts: [
    { text: "Loneliness — they miss the organic social side of a shared workplace", score: { audience: 3 } },
    { text: "Procrastination — they can't seem to start or sustain focus alone", score: { audience: 2 } },
    { text: "Burnout — they're overwhelmed and need structure to recover", score: { audience: 1 } },
    { text: "Isolation + focus — both equally", score: { audience: 0 } }
  ]},
  { section: "Audience Clarity", q: "If you had to turn away someone at the door, who would it be?", opts: [
    { text: "Someone who came to network and pitch — not to actually work", score: { audience: 3 } },
    { text: "Someone who can't sit quietly for 50 minutes", score: { audience: 2 } },
    { text: "Honestly, I'd welcome almost anyone with a laptop", score: { audience: 0 } },
    { text: "Someone doing shallow tasks — I want deep thinkers only", score: { audience: 1 } }
  ]},

  // PURPOSE & VALUES
  { section: "Purpose & Values", q: "What is the core belief behind making Creative Blocks free?", opts: [
    { text: "Community is a human need — charging for it changes who shows up and why", score: { purpose: 3 } },
    { text: "I want as many people as possible, and price is a barrier", score: { purpose: 1 } },
    { text: "I haven't fully decided — I might charge eventually", score: { purpose: 0 } },
    { text: "It's a lead generation strategy for paid services I'll offer later", score: { purpose: 2 } }
  ]},
  { section: "Purpose & Values", q: "In 5 years, what does success look like for Creative Blocks?", opts: [
    { text: "A network of free community sessions in multiple cities, run by trained hosts", score: { purpose: 3 } },
    { text: "A profitable brand with premium events, sponsorships, or a paid tier", score: { purpose: 2 } },
    { text: "A nonprofit registered organization with funding from grants or donors", score: { purpose: 2 } },
    { text: "I haven't thought that far yet", score: { purpose: 0 } }
  ]},

  // POSITIONING
  { section: "Positioning", q: "What makes Creative Blocks different from a regular coworking space or café?", opts: [
    { text: "The structured block format + the social hangout at the end — both are intentional", score: { positioning: 3 } },
    { text: "It's free and anyone can come", score: { positioning: 1 } },
    { text: "The community — you actually get to know people", score: { positioning: 2 } },
    { text: "I'm not sure we're that different yet", score: { positioning: 0 } }
  ]},
  { section: "Positioning", q: "What's the one sentence you'd want someone to say about Creative Blocks after their first session?", opts: [
    { text: "It felt like showing up to work with actual coworkers — minus all the office politics", score: { positioning: 3 } },
    { text: "I got more done in one day than I do in a whole week at home", score: { positioning: 2 } },
    { text: "I finally feel like I've found my people", score: { positioning: 3 } },
    { text: "It was a really nice, chill, productive day", score: { positioning: 1 } }
  ]},

  // TONE & VOICE
  { section: "Tone & Voice", q: "How do you want people to feel when they read your content or see your brand?", opts: [
    { text: "Seen — like someone finally gets the lonely side of remote work", score: { tone: 3 } },
    { text: "Motivated — like they have no excuse not to show up", score: { tone: 1 } },
    { text: "Calm and welcomed — no pressure, no performance", score: { tone: 2 } },
    { text: "Cool and inspired — like this is the community they didn't know they needed", score: { tone: 2 } }
  ]},
  { section: "Tone & Voice", q: "Which content style feels most natural to you?", opts: [
    { text: "Short, punchy, no fluff — like the website copy already is", score: { tone: 3 } },
    { text: "Warm and personal — more storytelling about attendees and moments", score: { tone: 2 } },
    { text: "Educational — tips on deep work, remote life, focus habits", score: { tone: 1 } },
    { text: "I post whatever feels right at the time", score: { tone: 0 } }
  ]},

  // BUSINESS MODEL ALIGNMENT
  { section: "Business Model", q: "How do you currently see Creative Blocks sustaining itself long-term?", opts: [
    { text: "Sponsorships from aligned brands (specialty coffee, productivity tools, etc.)", score: { biz: 3 } },
    { text: "A paid version for companies (corporate deep work days, team offsites)", score: { biz: 3 } },
    { text: "Purely free forever — I'll find another way to make income separately", score: { biz: 1 } },
    { text: "I'm still figuring this out", score: { biz: 0 } }
  ]},
  { section: "Business Model", q: "Would you ever offer a paid tier — like reserved spots, premium venues, or priority access?", opts: [
    { text: "Yes — as long as the core free experience stays intact for everyone", score: { biz: 3 } },
    { text: "Maybe, but I'm worried it changes the culture", score: { biz: 2 } },
    { text: "No — paid anything goes against the whole point", score: { biz: 1 } },
    { text: "I'd consider it only if the free model stopped working", score: { biz: 2 } }
  ]},
  { section: "Business Model", q: "If Creative Blocks trained hosts in other cities, what would the relationship look like?", opts: [
    { text: "A volunteer network — hosts run sessions because they believe in it", score: { biz: 1 } },
    { text: "A licensed or franchise model — hosts pay a small fee for the brand + system", score: { biz: 3 } },
    { text: "Hosts are paid employees or contractors of the brand", score: { biz: 2 } },
    { text: "I haven't thought about expansion yet", score: { biz: 0 } }
  ]}
];

const archetypes = [
  { name: "The Connector", tagline: "Community-first. Purpose-driven. Human above all.", min: 32, desc: "Your brand lives and breathes human connection. You're building something rare — a space where productivity and belonging coexist. The risk is vagueness; the opportunity is becoming the de facto brand for isolated remote workers worldwide.", color: "#C65A2E" },
  { name: "The Architect", tagline: "Structure creates freedom.", min: 22, desc: "You believe in systems — and that's your edge. The block format, the rules, the intentional design of the day: this is a brand that thinks deeply about how to engineer good experiences. Lead with the format more boldly.", color: "#4a7fa5" },
  { name: "The Catalyst", tagline: "Show up. Get unstuck. Move forward.", min: 14, desc: "Your brand is about momentum — getting people unstuck from the paralysis of working alone. You attract doers and builders. The hangout is almost secondary to the transformative feeling of a productive day.", color: "#5a8a5e" },
  { name: "The Wanderer", tagline: "Still finding your voice.", min: 0, desc: "The brand has strong instincts but lacks a clear north star yet. That's okay — it's early. The priority is to nail the audience first, then let positioning and tone flow from that clarity.", color: "#999" }
];

let current = 0;
let answers = [];

function startQuiz() {
  document.getElementById('intro').style.display = 'none';
  document.getElementById('quiz').style.display = 'block';
  renderQuestion();
}

function renderQuestion() {
  const q = questions[current];
  const wrap = document.getElementById('questionWrap');
  const pct = Math.round((current / questions.length) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `Question ${current + 1} of ${questions.length} · ${q.section}`;
  document.getElementById('backBtn').style.visibility = current === 0 ? 'hidden' : 'visible';
  document.getElementById('nextBtn').disabled = answers[current] === undefined;
  document.getElementById('nextBtn').textContent = current === questions.length - 1 ? 'See Results →' : 'Next →';

  wrap.innerHTML = `
    <div class="question-card">
      <div class="section-label">${q.section}</div>
      <div class="question-text">${q.q}</div>
      <div class="options">
        ${q.opts.map((o, i) => `
          <label class="option ${answers[current] === i ? 'selected' : ''}" onclick="selectOption(${i})">
            <input type="radio" name="opt" value="${i}" ${answers[current] === i ? 'checked' : ''}>
            ${o.text}
          </label>
        `).join('')}
      </div>
    </div>`;
}

function selectOption(i) {
  answers[current] = i;
  document.querySelectorAll('.option').forEach((el, idx) => el.classList.toggle('selected', idx === i));
  document.getElementById('nextBtn').disabled = false;
}

function goNext() {
  if (answers[current] === undefined) return;
  if (current < questions.length - 1) { current++; renderQuestion(); }
  else showResults();
}

function goBack() { if (current > 0) { current--; renderQuestion(); } }

function showResults() {
  document.getElementById('quiz').style.display = 'none';
  const res = document.getElementById('results');
  res.style.display = 'block';

  // Tally scores
  const totals = { audience: 0, purpose: 0, positioning: 0, tone: 0, biz: 0 };
  const maxes = { audience: 9, purpose: 6, positioning: 6, tone: 6, biz: 9 };
  answers.forEach((ai, qi) => {
    const scoreObj = questions[qi].opts[ai].score;
    Object.keys(scoreObj).forEach(k => totals[k] += scoreObj[k]);
  });

  const overall = Object.values(totals).reduce((a, b) => a + b, 0);
  const maxTotal = Object.values(maxes).reduce((a, b) => a + b, 0);
  const pct = Math.round((overall / maxTotal) * 100);

  const archetype = archetypes.find(a => overall >= a.min);

  const dims = [
    { key: 'audience', label: 'Audience Clarity', max: 9, tip: {
      0: "Critical: You're trying to serve everyone. Pick one specific person — the isolated remote worker — and talk only to them.",
      1: "Audience is fuzzy. Define one primary person with one specific pain. Everything else follows.",
      2: "Getting clearer. Push further — what does this person feel on a Sunday night thinking about Monday?",
      3: "Sharp. You know exactly who you're for and who you're not. Protect that."
    }},
    { key: 'purpose', label: 'Purpose & Values', max: 6, tip: {
      0: "You haven't committed to what this is for yet. That uncertainty will show up in your content. Decide.",
      1: "Purpose exists but feels instrumental. Why does this matter beyond the productivity outcome?",
      2: "You have values but haven't weaponized them yet. 'Free because community shouldn't cost money' is strong — build on it.",
      3: "Your 'why' is clear and consistent. Now make it visible in every touchpoint."
    }},
    { key: 'positioning', label: 'Positioning', max: 6, tip: {
      0: "You're not differentiated yet. What can Creative Blocks say that no coworking space, no productivity app, and no networking event can?",
      1: "Positioning is emerging but relies too much on price (free). Free is a tactic, not a position.",
      2: "Good instincts. The 'coworkers without the office' feeling is the positioning. Name it explicitly.",
      3: "Distinct and ownable. Now repeat this positioning across every piece of content."
    }},
    { key: 'tone', label: 'Tone & Voice', max: 6, tip: {
      0: "No consistent voice yet. The website tone is strong — short, confident, no fluff. Match that everywhere.",
      1: "Tone is inconsistent. Your audience is anti-performance; your content should be too.",
      2: "Voice is mostly there. Just avoid drifting into generic 'productivity tips' content that erodes identity.",
      3: "Tone is on-brand and consistent. Keep it human, keep it short."
    }},
    { key: 'biz', label: 'Business Model Alignment', max: 9, tip: {
      0: "No clear path to sustainability. This will create anxiety and eventually force decisions under pressure. Design the model now.",
      1: "You're committed to free, which is principled — but you need a parallel revenue model or this won't scale.",
      2: "You're thinking about this. Corporate deep work days or sponsorships are natural extensions. Pick one and test it.",
      3: "Business model is thought through and aligned with brand values. Now execute it."
    }}
  ];

  const getTag = (score, max) => {
    const r = score / max;
    if (r >= 0.75) return '<span class="tag tag-strong">Strong</span>';
    if (r >= 0.45) return '<span class="tag tag-medium">Developing</span>';
    return '<span class="tag tag-weak">Needs work</span>';
  };

  const getTipLevel = (score, max) => {
    const r = score / max;
    if (r >= 0.75) return 3;
    if (r >= 0.45) return 2;
    if (r >= 0.2) return 1;
    return 0;
  };

  res.innerHTML = `
    <div class="archetype-badge">Brand Archetype</div>
    <div class="archetype-name">${archetype.name}</div>
    <div class="archetype-tagline">"${archetype.tagline}"</div>
    
    <div class="score-grid">
      <div class="score-card">
        <div class="score-num" style="color:${pct >= 70 ? '#2d7a3a' : pct >= 45 ? '#b07d10' : '#c0392b'}">${pct}%</div>
        <div class="score-label">Overall Brand Clarity</div>
      </div>
      <div class="score-card">
        <div class="score-num" style="color:#C65A2E">${overall}/${maxTotal}</div>
        <div class="score-label">Total Score</div>
      </div>
    </div>

    <div class="section-result" style="border-left: 4px solid ${archetype.color}">
      <h3>What this archetype means for you</h3>
      <p>${archetype.desc}</p>
    </div>

    ${dims.map(d => `
      <div class="section-result">
        <h3>${d.label} ${getTag(totals[d.key], d.max)} <span style="font-family:sans-serif;font-size:0.8rem;color:#bbb;font-weight:normal">${totals[d.key]}/${d.max}</span></h3>
        <p>${d.tip[getTipLevel(totals[d.key], d.max)]}</p>
      </div>
    `).join('')}

    <div class="section-result" style="background:#fdf8f5; border: 2px solid #C65A2E;">
      <h3 style="color:#C65A2E">Your #1 priority right now</h3>
      <p>${getPriority(totals)}</p>
    </div>

    <div class="cta-restart">
      <button class="btn-restart" onclick="restart()">↺ Retake questionnaire</button>
    </div>
  `;
}

function getPriority(t) {
  const scores = [
    { key: 'audience', val: t.audience / 9, label: 'audience' },
    { key: 'purpose', val: t.purpose / 6, label: 'purpose' },
    { key: 'positioning', val: t.positioning / 6, label: 'positioning' },
    { key: 'tone', val: t.tone / 6, label: 'tone' },
    { key: 'biz', val: t.biz / 9, label: 'business model' }
  ];
  scores.sort((a, b) => a.val - b.val);
  const lowest = scores[0];
  const msgs = {
    audience: "Define one person. Not remote workers broadly — one specific human with one specific ache. Write their Monday morning in a sentence. Everything else — content, copy, events, expansion — flows from that.",
    purpose: "Get clear on why this exists beyond productivity. Your 'free because community shouldn't cost money' line is the beginning of a manifesto. Finish writing it. It will anchor every decision.",
    positioning: "Write the one thing Creative Blocks can say that nothing else can. Not 'free coworking' — that's a feature. What is the feeling no one else is selling? That's your position.",
    tone: "Your website copy is your best asset — match it everywhere. Short, direct, no performance. Apply that same voice to Instagram, emails, and host training materials.",
    biz: "Design a parallel revenue stream now, before the pressure forces a bad decision. Corporate deep work days or brand sponsorships are most on-brand. Run one experiment in the next 60 days."
  };
  return msgs[lowest.key];
}

function restart() {
  current = 0;
  answers = [];
  document.getElementById('results').style.display = 'none';
  document.getElementById('intro').style.display = 'block';
}
</script>

</body>
</html>
